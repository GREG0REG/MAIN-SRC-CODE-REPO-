<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    
    <!-- Gradient background matching the Aurora Borealis theme -->
    <gradient
        android:angle="135"
        android:startColor="#FF00BFA5"
        android:centerColor="#FF0091EA"
        android:endColor="#FF7C4DFF"
        android:type="linear" />
    
    <corners
        android:bottomLeftRadius="24dp"
        android:bottomRightRadius="24dp"
        android:topLeftRadius="24dp"
        android:topRightRadius="24dp" />
    
    <!-- Subtle border for glass effect -->
    <stroke
        android:width="1dp"
        android:color="#30FFFFFF" />
    
    <padding
        android:bottom="8dp"
        android:left="8dp"
        android:right="8dp"
        android:top="8dp" />
        
</shape>
