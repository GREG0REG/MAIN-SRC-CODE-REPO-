<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Painted natively: rounded gradient / Amoled / custom-image glass card.
         scaleType=fitXY so it always exactly fills the widget's real size,
         however the launcher has it laid out or resized. -->
    <ImageView
        android:id="@+id/widget_card_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- Circular progress ring. Square view + square bitmap + fitCenter
             means this is always a true circle, never a stretched oval. -->
        <ImageView
            android:id="@+id/widget_ring"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="fitCenter"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical"
            android:gravity="start">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:shadowColor="#40000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="3"
                android:text="Event Title"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:alpha="0.9" />

            <TextView
                android:id="@+id/widget_countdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-light"
                android:maxLines="2"
                android:shadowColor="#60000000"
                android:shadowDx="0"
                android:shadowDy="1"
                android:shadowRadius="4"
                android:text="2 hours left"
                android:textColor="#FFFFFF"
                android:textSize="19sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="0.95" />

        </LinearLayout>
    </LinearLayout>

</FrameLayout>
